# Application Settings
APP_NAME="AI Operating System Layer"
APP_ENV=development
DEBUG=true

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aios
DATABASE_URL=postgresql://postgres:postgres@db:5432/aios

# OpenAI (Primary LLM)
OPENAI_API_KEY=sk-placeholder

# Ollama (Secondary LLM)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# n8n
N8N_WEBHOOK_SECRET=random_secret_string
N8N_HOST=http://n8n:5678

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
